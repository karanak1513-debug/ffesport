rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Payment Screenshots ───────────────────────────────────
    match /payment_screenshots/{userId}/{imageId} {
      // Authenticated users can upload JPG/PNG under 2MB
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 2 * 1024 * 1024
                    && request.resource.contentType.matches('image/(jpeg|png|jpg)');
      
      allow read: if true;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── QR Code Images (uploaded via CreateTournamentModal) ───
    match /qr_codes/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Default: block everything else ───────────────────────
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
